<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drk_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:id="@+id/drk_tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Receiver Mode Avion : DÉSACTIVÉ"
        android:textSize="18sp"
        android:layout_marginBottom="24dp"
        android:textAlignment="center" />

    <Button
        android:id="@+id/drk_btnToggleAirplane"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Activer Receiver Avion"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/drk_btnSendCustom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Envoyer Custom Broadcast" />

</LinearLayout>